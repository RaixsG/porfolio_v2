---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Desarrollador Backend | portfolio">
  <Header slot="header" />

  <!-- HERO SECTION -->
  <section class="min-h-[70vh] flex flex-col justify-center space-y-6 animate-fade-in-up">
    <div>
      <h1 class="text-5xl md:text-7xl font-extrabold mb-6 tracking-tight">
        Hola.<br />
        <span class="text-text-muted">Soy un </span><span class="text-brand-accent">Desarrollador Backend.</span>
      </h1>
      <p class="text-xl md:text-2xl text-text-muted max-w-2xl font-mono leading-relaxed">
        Construyo APIs de alto rendimiento, escalo arquitecturas limpias y resuelvo problemas de datos. Menos ruido. Más performance.
      </p>
    </div>
    <div class="flex gap-4 pt-12">
      <a 
      	href="https://github.com/RaixsG"
        target="_blank" rel="noopener noreferrer"
        class="group inline-flex items-center gap-2 border border-brand-accent px-6 py-3 rounded-none font-mono font-bold hover:bg-brand-accent hover:text-bg-primary transition-all decoration-transparent text-white"
      >
        <span class="group-hover:animate-pulse">>&nbsp;</span>GitHub
      </a>
      <a 
        href="https://linkedin.com" 
        target="_blank" rel="noopener noreferrer"
        class="group inline-flex items-center gap-2 border border-border-subtle px-6 py-3 rounded-none font-mono font-bold hover:bg-border-subtle hover:text-white transition-all decoration-transparent text-text-muted"
      >
		LinkedIn
      </a>
    </div>
  </section>

  <!-- STACK SECTION -->
  <section id="stack" class="relative scroll-mt-32 pt-16 border-t border-border-subtle/50">
    <h2 class="text-3xl font-bold flex items-center gap-4 mb-12">
      <span class="text-brand-accent font-mono text-xl">01.</span> Stack Tecnológico
    </h2>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 font-mono relative z-10">
      <div class="space-y-4 p-8 border border-border-subtle bg-bg-primary hover:border-brand-accent transition-colors shadow-[4px_4px_0_var(--color-border-subtle)] hover:shadow-[4px_4px_0_var(--color-brand-accent)] cursor-crosshair">
        <h3 class="text-white text-xl border-b border-border-subtle pb-4 mb-6">Lenguajes</h3>
        <ul class="text-text-muted space-y-3">
			<li class="flex items-center gap-2 transition-colors hover:text-white"><span class="text-brand-accent">{'>>'}</span> Python</li>
			<!-- <li class="flex items-center gap-2 transition-colors hover:text-white"><span class="text-brand-accent">{'>>'}</span> Java</li> -->
			<li class="flex items-center gap-2 transition-colors hover:text-white"><span class="text-brand-accent">{'>>'}</span> JavaScript</li>
			<li class="flex items-center gap-2 transition-colors hover:text-white"><span class="text-brand-accent">{'>>'}</span> Dart</li>
          <!-- <li class="flex items-center gap-2 transition-colors hover:text-white"><span class="text-brand-accent">{'>>'}</span> SQL</li> -->
        </ul>
      </div>
      
      <div class="space-y-4 p-8 border border-border-subtle bg-bg-primary hover:border-brand-accent transition-colors shadow-[4px_4px_0_var(--color-border-subtle)] hover:shadow-[4px_4px_0_var(--color-brand-accent)] cursor-crosshair">
        <h3 class="text-white text-xl border-b border-border-subtle pb-4 mb-6">Frameworks</h3>
        <ul class="text-text-muted space-y-3">
          <li class="flex items-center gap-2 transition-colors hover:text-white"><span class="text-brand-accent">{'>>'}</span> Django / DRF</li>
          <li class="flex items-center gap-2 transition-colors hover:text-white"><span class="text-brand-accent">{'>>'}</span> FastAPI</li>
          <li class="flex items-center gap-2 transition-colors hover:text-white"><span class="text-brand-accent">{'>>'}</span> Flutter</li>
          <li class="flex items-center gap-2 transition-colors hover:text-white"><span class="text-brand-accent">{'>>'}</span> Svelte</li>
          <li class="flex items-center gap-2 transition-colors hover:text-white"><span class="text-brand-accent">{'>>'}</span> Astro</li>
        </ul>
      </div>
      
      <div class="space-y-4 p-8 border border-border-subtle bg-bg-primary hover:border-brand-accent transition-colors overflow-hidden shadow-[4px_4px_0_var(--color-border-subtle)] hover:shadow-[4px_4px_0_var(--color-brand-accent)] cursor-crosshair">
        <h3 class="text-white text-xl border-b border-border-subtle pb-4 mb-6">Infraestructura</h3>
        <ul class="text-text-muted space-y-3 relative z-10">
          <li class="flex items-center gap-2 transition-colors hover:text-white"><span class="text-brand-accent">{'>>'}</span> Docker</li>
          <li class="flex items-center gap-2 transition-colors hover:text-white"><span class="text-brand-accent">{'>>'}</span> Git</li>
          <!-- <li class="flex items-center gap-2 transition-colors hover:text-white"><span class="text-brand-accent">{'>>'}</span> Git & CI/CD</li> -->
          <!-- <li class="flex items-center gap-2 transition-colors hover:text-white"><span class="text-brand-accent">{'>>'}</span> AWS / GCP</li> -->
        </ul>
      </div>
    </div>
  </section>

  <!-- PROJECTS SECTION -->
  <section id="projects" class="scroll-mt-32 pt-24 pb-12 relative">
    <div class="absolute left-0 top-24 w-px h-full bg-gradient-to-b from-brand-accent/50 to-transparent hidden md:block opacity-30"></div>
    <div class="md:pl-12">
      <h2 class="text-3xl font-bold flex items-center gap-4 mb-12">
        <span class="text-brand-accent font-mono text-xl">02.</span> Casos de Estudio
      </h2>
      
      <div class="grid gap-12 hover-group">
        {sortedProjects.map((project) => (
          <a href={`/projects/${project.id}`} class="block group relative p-8 bg-[#0a0a0a] border border-border-subtle hover:border-brand-accent transition-all duration-300 decoration-transparent shadow-none focus:outline-none focus:ring-1 focus:ring-brand-accent">
            <div class="absolute top-0 right-0 w-3 h-3 border-t-2 border-r-2 border-transparent group-hover:border-brand-accent transition-colors m-px"></div>
            <div class="absolute bottom-0 left-0 w-3 h-3 border-b-2 border-l-2 border-transparent group-hover:border-brand-accent transition-colors m-px"></div>

            <div class="flex flex-col md:flex-row gap-6 justify-between items-start w-full">
              <div class="space-y-4 w-full">
                <h3 class="text-2xl font-bold text-white group-hover:text-brand-accent transition-colors">
                  {project.data.title}
                </h3>
                <p class="text-text-muted leading-relaxed font-sans max-w-4xl pt-2">
                  {project.data.description}
                </p>
                
                <ul class="flex flex-wrap gap-2 font-mono text-xs pt-4">
                  {project.data.tags.map((tag: string) => (
                    <li class="px-3 py-1 bg-[#111] border border-border-subtle text-text-muted group-hover:border-brand-accent/40 group-hover:text-white transition-colors">
                      {tag}
                    </li>
                  ))}
                </ul>
              </div>
              
              <div class="bg-[#111] text-text-muted px-4 py-2 border border-border-subtle group-hover:border-brand-accent/50 group-hover:text-brand-accent transition-colors hidden md:flex items-center gap-2 mt-1 whitespace-nowrap">
                <span class="font-mono text-xs tracking-wider">VER_DETALLE</span>
                <span>-></span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .animate-fade-in-up {
    animation: fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
