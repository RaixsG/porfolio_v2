---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
---

<BaseLayout title="404 - Página no encontrada" description="Error 404: La página que buscas no existe en este portafolio.">
  <Header slot="header" />
  
  <section class="flex flex-col items-center justify-center text-center space-y-6 min-h-[50vh]">
    <h1 class="text-7xl md:text-9xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-purple-400 to-blue-400">
      404
    </h1>
    <h2 class="text-2xl md:text-3xl font-semibold text-gray-100">
      Página no encontrada
    </h2>
    <p class="text-gray-400 max-w-md mb-8">
      Lo sentimos, la ruta que intentaste visitar no existe o ha sido movida. Vuelve a una ruta segura para seguir explorando.
    </p>
    <a 
      href="/" 
      class="inline-flex items-center justify-center px-6 py-3 rounded-xl bg-white/5 hover:bg-white/10 border border-white/10 text-white transition-all duration-300"
    >
      Volver al Inicio
    </a>
  </section>

  <Footer slot="footer" />
</BaseLayout>
