---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Backend Developer Portfolio" } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="max-w-4xl mx-auto w-full px-6 md:px-12 flex flex-col min-h-screen">
    <slot name="header" />
    
    <main class="flex-grow py-12 md:py-24 space-y-24">
      <slot />
    </main>

    <slot name="footer" />
  </body>
</html>
